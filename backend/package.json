{
  "name": "smarthunt-backend",
  "version": "1.0.0",
  "description": "SmartHunt API V2 — Fastify + pg + PostgreSQL",
  "private": true,
  "scripts": {
    "dev":        "tsx watch src/server.ts",
    "build":      "tsc --project tsconfig.json",
    "start":      "node dist/server.js",
    "db:push":    "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate":"prisma generate",
    "db:studio":  "prisma studio",
    "test":       "jest --passWithNoTests",
    "bridge":     "cd scraper && npm install --silent && npx tsx src/bridge.ts",
    "bridge:prod":"cd scraper && API_URL=$API_URL INTERNAL_API_KEY=$INTERNAL_API_KEY npx tsx src/bridge.ts"
  },
  "dependencies": {
    "@fastify/cors":       "^9.0.1",
    "@fastify/helmet":     "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify":             "^4.27.0",
    "pg":                  "^8.20.0",
    "pino-pretty":         "^11.0.0",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/pg":   "^8.20.0",
    "prisma":      "^6.19.3",
    "tsx":         "^4.15.7",
    "typescript":  "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
