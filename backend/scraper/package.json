{
  "name": "smarthunt-scraper",
  "version": "2.0.0",
  "description": "Scrapers quotidiens Nantes Métropole — Leclerc, Carrefour, Lidl",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape":          "npx tsx src/run.ts --daily",
    "scrape:daily":    "npx tsx src/run.ts --daily",
    "scrape:weekly":   "npx tsx src/run.ts --weekly",
    "scrape:stores":   "npx tsx src/run.ts --stores",
    "scrape:openprices": "npx tsx src/run.ts --openprices",
    "scrape:lidl":     "npx tsx src/run.ts --lidl",
    "bridge":          "tsx src/bridge.ts",
    "bridge:prod":     "API_URL=$API_URL INTERNAL_API_KEY=$INTERNAL_API_KEY tsx src/bridge.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsx":         "^4.15.7",
    "typescript":  "^5.4.5"
  }
}
