# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://smarthunt:password@localhost:5432/smarthunt_db"

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Sécurité ─────────────────────────────────────────────────────────────────
# Clé secrète pour les routes internes (scraper → /v1/internal/update-prices)
INTERNAL_API_KEY=change-me-in-production

# ─── Rate limiting (requêtes / minute par IP) ─────────────────────────────────
RATE_LIMIT_MAX=100

# ─── CORS — origines autorisées (séparées par virgule) ───────────────────────
ALLOWED_ORIGINS=exp://localhost:8081,https://smarthunt.app
